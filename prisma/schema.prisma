// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  email     String?  @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  projectFiles ProjectFile[]
}

model JobHistory {
  id            String    @id @default(cuid())
  jobName       String
  clientName    String
  startDate     DateTime?
  endDate       DateTime?
  description   String?
  amount        Decimal?  @db.Decimal(15, 2)
  status        JobStatus @default(IN_PROGRESS)
  projectFileId String?   @unique
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

enum JobStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model QuoteRequest {
  id          String             @id @default(cuid())
  contactName String
  companyName String?
  phone       String
  email       String?
  serviceType String
  details     String
  status      QuoteRequestStatus @default(NEW)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

enum QuoteRequestStatus {
  NEW
  IN_PROGRESS
  REPLIED
  CLOSED
}

model MasterData {
  id        String   @id @default(cuid())
  category  String
  key       String
  value     String
  label     String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([category, key])
}

model ProjectFile {
  id               String            @id @default(cuid())
  projectCode      String            @unique
  projectName      String
  subject          String?
  quotationNo      String?
  revisionNo       String            @default("Rev.1")
  quotationDate    DateTime?
  customerName     String?
  billTo           String?
  dear             String?
  supervisorName   String?
  paymentTermsText String?
  amountTextTh     String?
  status           ProjectFileStatus @default(DRAFT)
  subtotal         Decimal           @default(0) @db.Decimal(15, 2)
  overheadPercent  Decimal           @default(0) @db.Decimal(5, 2)
  overheadAmount   Decimal           @default(0) @db.Decimal(15, 2)
  total            Decimal           @default(0) @db.Decimal(15, 2)
  discount         Decimal           @default(0) @db.Decimal(15, 2)
  grandTotal       Decimal           @default(0) @db.Decimal(15, 2)
  createdById      String?
  createdBy        User?             @relation(fields: [createdById], references: [id])
  lines            ProjectFileLine[]
  versions         ProjectFileVersion[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

enum ProjectFileStatus {
  DRAFT
  CONFIRMED
  APPROVED
}

model ProjectFileLine {
  id                String              @id @default(cuid())
  projectFileId     String
  projectFile       ProjectFile         @relation(fields: [projectFileId], references: [id], onDelete: Cascade)
  sortOrder         Int                 @default(0)
  lineType          ProjectFileLineType @default(ITEM)
  itemNo            String?
  description       String
  quantity          Decimal?            @db.Decimal(15, 2)
  unit              String?
  materialUnitPrice Decimal?            @db.Decimal(15, 2)
  materialAmount    Decimal?            @db.Decimal(15, 2)
  laborUnitPrice    Decimal?            @db.Decimal(15, 2)
  laborAmount       Decimal?            @db.Decimal(15, 2)
  lineTotal         Decimal?            @db.Decimal(15, 2)
  remark            String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([projectFileId, sortOrder])
}

enum ProjectFileLineType {
  SECTION
  ITEM
  NOTE
}

model ProjectFileVersion {
  id            String      @id @default(cuid())
  projectFileId String
  projectFile   ProjectFile @relation(fields: [projectFileId], references: [id], onDelete: Cascade)
  versionNo     Int
  snapshot      Json
  pdfPath       String?
  createdAt     DateTime    @default(now())

  @@unique([projectFileId, versionNo])
}

model Album {
  id          String       @id @default(cuid())
  title       String
  description String?
  sortOrder   Int          @default(0)
  isActive    Boolean      @default(true)
  images      AlbumImage[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model AlbumImage {
  id        String   @id @default(cuid())
  albumId   String
  album     Album    @relation(fields: [albumId], references: [id], onDelete: Cascade)
  url       String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([albumId, sortOrder])
}
